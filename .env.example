# travel-mcp environment variables.
# Copy to .env and fill in. Never commit the real .env.

# REQUIRED — absolute path to your Obsidian-style vault root.
# All profile, trip-plan, and companion data lives under this root.
TRAVEL_MCP_VAULT_PATH=/path/to/your/vault

# OPTIONAL — folder inside the vault where Profile.md, Trips/, Companions/ live.
# Default: "🧳 Travel" (auto-created on first healthcheck).
# TRAVEL_MCP_PROFILE_FOLDER=🧳 Travel

# OPTIONAL — Claude routing. Default is Tier-1 (Claude Max via CLI, zero per-token cost).
# Set to "1" only if your CLI is unavailable; falls through to ANTHROPIC_API_KEY.
# CLAUDE_ROUTER_DISABLE_CLI=0
# CLAUDE_ROUTER_PREFER_API_KEY=0
# ANTHROPIC_API_KEY=sk-ant-...   # only consulted on fallback paths

# OPTIONAL — model override. Default: claude-sonnet-4-6 for analyzers.
# TRAVEL_MCP_MODEL=claude-sonnet-4-6
